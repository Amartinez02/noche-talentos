{% extends "layout.njk" %}

{% block title %}Dashboard — Admin{% endblock %}

{% block body %}
<div class="page-admin">
  <div class="grain"></div>

  <nav class="admin-nav">
    <div class="admin-brand"><img src="/static/img/vive-logo.png" alt="VIVE" class="nav-logo"><span>Admin</span></div>
    <div class="admin-nav-links">
      <a href="/admin/dashboard" class="active">Dashboard</a>
      <a href="/admin/boletas">Boletas</a>
      <a href="/admin/participantes">Participantes</a>
      <a href="/admin/ministerios">Ministerios</a>
      <a href="/admin/scanner">Escáner</a>
      <form method="POST" action="/admin/logout" style="display:inline">
        <button type="submit" class="nav-logout">Salir</button>
      </form>
    </div>
  </nav>

  <main class="admin-main">
    <h2 class="admin-page-title">Dashboard</h2>
    <p class="admin-event-info">Noche de Talentos · 25 Julio 2026</p>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number">{{ total }}</span>
        <span class="stat-label">Boletas emitidas</span>
      </div>
      <div class="stat-card stat-validated">
        <span class="stat-number">{{ validated }}</span>
        <span class="stat-label">Validadas en puerta</span>
      </div>
      <div class="stat-card stat-paid">
        <span class="stat-number">{{ paid }}</span>
        <span class="stat-label">Pagos confirmados</span>
      </div>
      <div class="stat-card stat-pending">
        <span class="stat-number">{{ pending }}</span>
        <span class="stat-label">Sin validar</span>
      </div>
    </div>

    <div class="quick-actions">
      <a href="/admin/scanner" class="btn-primary">📷 Abrir Escáner QR</a>
      <a href="/admin/boletas" class="btn-secondary">📋 Ver boletas</a>
      <a href="/admin/participantes" class="btn-secondary">🎤 Gestionar participantes</a>
    </div>
  </main>
</div>
{% endblock %}
